# {{ ansible_managed }}
# Secret environment for the zai-auth systemd unit (EnvironmentFile). Root-only
# (0600); read by systemd before it drops to the zai-auth user, so the daemon
# never reads this file itself. Rendered by the zai-auth role — never edited
# on the CT (git pull on CT 100 + re-run provision.yml is the update story).

# Postgres store. IP DERIVED from the postgres CT's CTID via hostvars, never
# hardcoded. Migrations already ran at provision time (see tasks), so startup
# is just app boot + DB connect.
DATABASE_URL={{ zai_auth_database_url }}

# Signs Django sessions + CSRF tokens. Set explicitly (stable, from
# /root/.zai-secrets) so logins survive a rebuild.
SECRET_KEY={{ zai_auth_secret_key }}
DEBUG=false

ALLOWED_HOSTS={{ zai_auth_allowed_hosts | join(',') }}
CSRF_TRUSTED_ORIGINS={{ zai_auth_url }}

# Anchors the atproto OAuth client_id, the OIDC issuer, and the redirect/JWKS
# URLs — must be the public HTTPS origin Caddy fronts (account.{{ cluster_domain }}).
PUBLIC_BASE_URL={{ zai_auth_url }}

# The two OAuth/OIDC signing keys (PKCS8 PEM), rendered onto this CT by the
# role from the group_vars secrets. atproto mandates ES256 (P-256) for DPoP +
# client assertion; the OIDC id_token uses RS256 for broad OIDC-client compat.
ATPROTO_EC_PRIVATE_KEY_PATH={{ zai_auth_atproto_ec_key_path }}
OIDC_RSA_PRIVATE_KEY_PATH={{ zai_auth_oidc_rsa_key_path }}

# The one OIDC relying party today: Open WebUI. Secret is shared between this
# app and the open-webui role's OAUTH_CLIENT_SECRET (same group_vars value).
OIDC_CLIENT_ID={{ zai_auth_oidc_client_id }}
OIDC_CLIENT_SECRET={{ zai_auth_oidc_client_secret }}
OIDC_REDIRECT_URIS={{ zai_auth_oidc_redirect_uris | join(',') }}
