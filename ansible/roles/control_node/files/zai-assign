#!/usr/bin/env bash
# zai-assign — thin wrapper over ansible/assign.yml. Assign a service to a CTID:
#
#   zai-assign npm 104                  # npm → CTID 104 (10.1.1.104)
#   zai-assign npm 105 -e reassign=true # move an existing assignment
#
# No logic lives here — the playbook validates and persists the assignment.
set -euo pipefail
if [[ $# -lt 2 ]]; then
  echo "usage: zai-assign <service> <ctid> [extra ansible args]" >&2
  exit 64
fi
service="$1"; ctid="$2"; shift 2
# Run from the ansible dir so ansible.cfg loads regardless of the caller's CWD —
# it supplies the inventory (relative: inventory/) and the vault password file.
# Without this, calling zai-assign from elsewhere finds no inventory and can't
# decrypt the vault.
cd /opt/zai-ops/ansible
exec ansible-playbook assign.yml \
  -e "service=$service ctid=$ctid" "$@"
