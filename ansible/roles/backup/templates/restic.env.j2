# {{ ansible_managed }}
# Sourced by /opt/zai-ops/bin/zai-backup. Root-only (0600), git-ignored.
# Secrets + host-specific values only — non-secret config lives in the script
# (in git). Regenerated by the `backup` role; not touched by a routine git pull.
export RESTIC_REPOSITORY="{{ backup_repository }}"
export RESTIC_PASSWORD="{{ restic_repo_password }}"
export AWS_ACCESS_KEY_ID="{{ object_store_access_key }}"
export AWS_SECRET_ACCESS_KEY="{{ object_store_secret_key }}"
export AWS_DEFAULT_REGION="{{ backup_s3_region }}"
# The postgres CT's internal IP, for the Tier-2 pg_dumpall. Empty until the
# postgres CT is assigned (zai-assign) and this env is re-rendered; the script
# only uses it when postgres_enabled=true.
export ZAI_POSTGRES_HOST="{{ hostvars['postgres'].ansible_host | default('') }}"
