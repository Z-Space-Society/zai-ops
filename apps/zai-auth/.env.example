# ZAI Auth — environment template. Copy to `.env` and fill in.
# Placeholders only: NEVER commit real secrets. `.env` is git-ignored.

# --- Core ---------------------------------------------------------------------
# Generate one, e.g.: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Origins trusted for CSRF on POST (Django checks the browser Origin header).
# Required when served behind an HTTPS proxy/tunnel: the browser sends an
# `https://` Origin while the app sees the forwarded request as `http`. To test
# the live atproto login locally, run a tunnel (e.g. `cloudflared tunnel --url
# http://127.0.0.1:8000`), then set this and PUBLIC_BASE_URL to its https origin
# and add the tunnel host to ALLOWED_HOSTS. The atproto auth server must fetch
# client-metadata.json over public HTTPS, so loopback alone can't do atproto login.
CSRF_TRUSTED_ORIGINS=

# Public HTTPS origin this app is served from. Anchors the OAuth client_id, the
# OIDC issuer, and redirect/JWKS URLs. atproto requires this to be public HTTPS
# in production; for local dev use a tunnel or the localhost dev convention.
PUBLIC_BASE_URL=http://localhost:8000

# --- Database (Postgres, CT 102 — assumed provisioned) ------------------------
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/zai_auth

# --- Signing keys (PEM private keys; generate with manage.py generate_keys) ----
# atproto mandates ES256 (P-256) for DPoP + client assertion; the OIDC id_token
# uses RS256. Two keys, both published (public halves) via the JWKS endpoint.
ATPROTO_EC_PRIVATE_KEY_PATH=keys/atproto_ec_private.pem
OIDC_RSA_PRIVATE_KEY_PATH=keys/oidc_rsa_private.pem

# --- OIDC relying party (Open WebUI) ------------------------------------------
OIDC_CLIENT_ID=open-webui
OIDC_CLIENT_SECRET=replace-with-a-shared-secret
OIDC_REDIRECT_URIS=https://chat.example.com/oauth/oidc/callback

# --- UI ------------------------------------------------------------------------
# Public origin of the cluster's chat app (Open WebUI). Blank hides the nav's
# "Chat" link (e.g. local dev with no Open WebUI configured).
CHAT_URL=https://chat.example.com
