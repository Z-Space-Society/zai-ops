# {{ ansible_managed }}
# HappyView runtime configuration. Read by systemd via EnvironmentFile before the
# process drops privilege — never world-readable (0600 root:root on disk).

DATABASE_URL={{ happyview_database_url }}
PUBLIC_URL={{ happyview_public_url }}

# Session cookie signing key — must be 64+ chars. Stable across rebuilds so existing
# sessions survive a re-provision (unset, HappyView would generate a random key and
# invalidate all active sessions on restart).
SESSION_SECRET={{ happyview_session_secret }}

# Base64-encoded 32-byte key for encrypting OAuth tokens at rest. IMMUTABLE once
# AT Protocol OAuth tokens have been stored — changing it invalidates all stored
# tokens and forces every connected account to re-authenticate.
TOKEN_ENCRYPTION_KEY={{ happyview_token_encryption_key }}

HOST={{ happyview_host }}
PORT={{ happyview_port }}
