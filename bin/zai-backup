#!/usr/bin/env bash
# zai-backup — back up the control node's runtime state to the cluster object
# store, and provide ad-hoc access to the backup repository.
#
#   zai-backup              run the backup (also what the systemd timer fires)
#   zai-backup snapshots    list snapshots
#   zai-backup check        verify repository integrity
#   zai-backup restore …    restore — any other verb is passed straight to restic
#
# Implemented with restic, but that's an implementation detail: operators talk to
# the *backup*, not to restic. The non-secret config below lives in git, so edits
# are live on `git pull` (no re-provision). Secrets and host-specific values
# (repo URL, creds, the postgres CT's IP) come from the env file the backup role
# renders once at provision — see ansible/roles/backup/.
set -euo pipefail

# Secrets + host-specific values: RESTIC_REPOSITORY, RESTIC_PASSWORD, AWS_*,
# ZAI_POSTGRES_HOST. Root-only (0600), git-ignored, regenerated by Ansible.
source /etc/zai-backup/restic.env

# --- config (in git — edit here, live on `git pull`) ------------------------
# Always backed up: small but unreproducible runtime state. Losing it turns a
# reflash from "lost cluster" into "repo + restored state".
backup_paths=(
  /opt/zai-ops/ansible/group_vars/all/vault.yml   # Proxmox API token (encrypted)
  /root/.vault_pass                               # vault password (host root = trust boundary)
  /root/.ssh/id_ed25519                           # key injected into every service CT
  /root/.ssh/id_ed25519.pub
  /root/.zai-secrets                              # auto-generated secrets (object-store key, restic pw)
)
# Backed up only if present — the inference-node roster doesn't exist until the
# first node is enrolled.
backup_optional_paths=(
  /opt/zai-ops/ansible/inventory/local.yml
)
# restic forget --prune retention, applied after each run.
keep_daily=7
keep_weekly=4
keep_monthly=6
# Tier 2: stream a cluster-wide pg_dumpall from the postgres CT into the same
# repo (tag zai-postgres). Flip to true once the postgres CT is provisioned and
# backup.yml has written ZAI_POSTGRES_HOST into the env. No playbook re-run needed.
postgres_enabled=false
# ----------------------------------------------------------------------------

run_backup() {
  # First run: create the repo. `restic cat config` is the cheap "is this repo
  # initialised?" probe — non-zero on a fresh bucket.
  if ! restic cat config >/dev/null 2>&1; then
    echo "zai-backup: initialising restic repository"
    restic init
  fi

  local paths=( "${backup_paths[@]}" )
  local p
  for p in "${backup_optional_paths[@]}"; do
    [ -e "$p" ] && paths+=( "$p" )
  done

  echo "zai-backup: backing up control-node state"
  restic backup --tag zai-control-node "${paths[@]}"

  if [ "$postgres_enabled" = true ]; then
    # Cluster-wide pg_dumpall over SSH (peer auth as the postgres superuser on
    # the CT) streamed straight into restic via stdin — no dump file lands on
    # disk on either box. --clean --if-exists makes it restorable onto a
    # populated cluster. set -euo pipefail + exit propagation through su/ssh mean
    # a failed dump fails the job rather than snapshotting a partial dump.
    echo "zai-backup: dumping Postgres from the postgres CT"
    ssh "root@${ZAI_POSTGRES_HOST}" "su - postgres -c 'pg_dumpall --clean --if-exists'" \
      | restic backup --tag zai-postgres --stdin --stdin-filename pg_dumpall.sql
  fi

  echo "zai-backup: pruning old snapshots"
  restic forget --tag zai-control-node \
    --keep-daily "$keep_daily" --keep-weekly "$keep_weekly" --keep-monthly "$keep_monthly" --prune
  if [ "$postgres_enabled" = true ]; then
    restic forget --tag zai-postgres \
      --keep-daily "$keep_daily" --keep-weekly "$keep_weekly" --keep-monthly "$keep_monthly" --prune
  fi
  echo "zai-backup: done"
}

# `run` (the default, and what the timer fires) is the only verb we own; restic
# has no `run` subcommand, so everything else is forwarded as an ad-hoc query
# against the repo — snapshots, check, restore, forget, … — with the env loaded.
case "${1:-run}" in
  run) run_backup ;;
  *)   exec restic "$@" ;;
esac
