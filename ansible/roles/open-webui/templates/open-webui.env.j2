# {{ ansible_managed }}
# Secret environment for the open-webui systemd unit (EnvironmentFile). Root-only
# (0600); read by systemd before it drops to the open-webui user, so the daemon never
# reads this file itself. Rendered by the open-webui role — never edited on the CT.
# OpenWebUI has no config file: it is configured entirely by these variables.

# Postgres store (users, chats, settings). IP DERIVED from the postgres CT's CTID via
# hostvars, never hardcoded. OpenWebUI runs its Alembic migrations against this on
# startup, so the DB + role must already exist — the role provisions them earlier.
DATABASE_URL={{ openwebui_database_url }}

# Signs OpenWebUI's session JWTs. Set EXPLICITLY (stable, from /root/.zai-secrets) so
# logins survive a rebuild — unset, OpenWebUI writes a random key into DATA_DIR that a
# fresh CT would regenerate, invalidating every existing session.
WEBUI_SECRET_KEY={{ openwebui_secret_key }}

# --- Model backend: the litellm gateway (chat + RAG embeddings) -------------------
# One OpenAI-compatible upstream for everything. Ollama probing is off (we have no
# Ollama); the key is litellm's master key.
ENABLE_OPENAI_API=true
ENABLE_OLLAMA_API=false
OPENAI_API_BASE_URL={{ openwebui_openai_base_url }}
OPENAI_API_KEY={{ openwebui_openai_api_key }}

# RAG embeddings via litellm (engine=openai) rather than OpenWebUI's local
# sentence-transformers model — no multi-GB model download, and embeddings track
# litellm's availability. The model name must match what litellm serves.
RAG_EMBEDDING_ENGINE={{ openwebui_rag_embedding_engine }}
RAG_EMBEDDING_MODEL={{ openwebui_rag_embedding_model }}
RAG_OPENAI_API_BASE_URL={{ openwebui_openai_base_url }}
RAG_OPENAI_API_KEY={{ openwebui_openai_api_key }}

# --- OIDC login: zai-auth is the ONLY way in ---------------------------------------
# zai-auth is the cluster's sole identity provider (ATProto handle -> OIDC id_token).
# Local signup/login are disabled so there is exactly one account per member, keyed
# by their DID — see docs/decisions/0005-zai-auth-over-aip.md.
ENABLE_OAUTH_SIGNUP=true
ENABLE_SIGNUP=false
ENABLE_LOGIN_FORM=false
OAUTH_CLIENT_ID={{ openwebui_oidc_client_id }}
OAUTH_CLIENT_SECRET={{ openwebui_oidc_client_secret }}
OPENID_PROVIDER_URL={{ openwebui_oidc_provider_url }}
OAUTH_PROVIDER_NAME=ZAI
OAUTH_SCOPES=openid email profile
OAUTH_USERNAME_CLAIM=handle
OAUTH_EMAIL_CLAIM=email
DEFAULT_USER_ROLE=user

# --- Runtime paths + public URL ---------------------------------------------------
# DATA_DIR is the unit's one writable path; HF_HOME/SENTENCE_TRANSFORMERS_HOME point
# inside it so any library cache lands in a path writable under ProtectSystem=strict.
DATA_DIR={{ openwebui_data_dir }}
HF_HOME={{ openwebui_hf_home }}
SENTENCE_TRANSFORMERS_HOME={{ openwebui_hf_home }}
WEBUI_URL={{ openwebui_url }}
HOST={{ openwebui_host }}
PORT={{ openwebui_port }}

# Migrations run automatically on startup (the default) — made explicit for clarity.
ENABLE_DB_MIGRATIONS=true
