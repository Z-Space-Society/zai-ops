# {{ ansible_managed }}
# Secret environment for the litellm systemd unit (EnvironmentFile). Root-only
# (0600); read by systemd before it drops to the litellm user, so the daemon never
# reads this file itself. Rendered by the litellm role — never edited on the CT.
#
# DATABASE_URL points at the litellm DB on the postgres CT (internal IP DERIVED
# from its CTID via hostvars, never hardcoded). LiteLLM runs Prisma migrations
# against this on first start, so the DB + role must already exist — the role
# provisions them earlier in the same play.
DATABASE_URL={{ litellm_database_url }}

# Proxy admin/root API key (clients + admin UI authenticate with this).
LITELLM_MASTER_KEY={{ litellm_master_key }}

# Persist runtime-added models/keys/teams in Postgres rather than only config.yaml.
# Requires DATABASE_URL to be set even when true — the model store *is* that DB.
STORE_MODEL_IN_DB=true
