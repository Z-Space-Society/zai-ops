# {{ ansible_managed }}
# Caddy reverse proxy — routes are git-tracked (caddy_proxy_hosts), not UI state.

{
{% if caddy_tls_enabled | bool %}
    # We supply origin TLS ourselves (Cloudflare Origin CA cert); never let Caddy
    # try to obtain its own certs over ACME — the Debian package has no DNS
    # plugin and ACME would fail behind Cloudflare anyway.
    auto_https disable_redirects
{% else %}
    # No Origin CA cert in the vault yet — serve plain HTTP only (no ACME).
    auto_https off
{% endif %}

    # Default admin endpoint, localhost-only — `caddy reload` uses it. Not LAN-exposed.
    admin localhost:2019
}

{% if caddy_tls_enabled | bool %}
# Reusable snippet: the wildcard Cloudflare Origin CA cert covers every route.
(origin_tls) {
    tls {{ caddy_cert_path }} {{ caddy_key_path }}
}

{% endif %}
# Plain HTTP catch-all: health probe, plus (when TLS is on) redirect everything
# else to HTTPS. handle blocks are mutually exclusive and evaluated in order, so
# /healthz returns "ok" instead of being caught by the redirect. Keeps the config
# valid (and the CT answerable) even when caddy_proxy_hosts is empty.
:80 {
    handle /healthz {
        respond "ok" 200
    }
{% if caddy_tls_enabled | bool %}
    handle {
        redir https://{host}{uri}
    }
{% endif %}
}

{% for h in caddy_proxy_hosts %}
{% if caddy_tls_enabled | bool %}
{{ h.domain }} {
    import origin_tls
{% else %}
http://{{ h.domain }} {
{% endif %}
{% if h.redirects is defined and h.redirects %}
    # handle blocks are mutually exclusive and evaluated in order (same idiom
    # as the :80 catch-all above) — each redirect is checked before falling
    # through to the catch-all reverse_proxy.
{% for r in h.redirects %}
    handle {{ r.from }} {
        # redir's Caddyfile grammar is `redir [<matcher>] <to> [<code>]` — with
        # exactly two bare args Caddy reads them as <matcher> <to>, not <to>
        # <code> (confirmed via `caddy adapt`: a 2-arg redir here silently
        # became a matcher on r.to and a Location header literally "302").
        # The `*` forces an unambiguous 3-arg parse; real scoping already
        # comes from the enclosing handle block, so `*` (match everything
        # that reaches here) is correct, not redundant.
        redir * {{ r.to }} {{ r.code | default(302) }}
    }
{% endfor %}
    handle {
        reverse_proxy {{ hostvars[h.service].ansible_host }}:{{ h.port }}
    }
{% else %}
    reverse_proxy {{ hostvars[h.service].ansible_host }}:{{ h.port }}
{% endif %}
}
{% endfor %}
