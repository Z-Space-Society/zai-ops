#!/usr/bin/env bash
# zai-assign — thin wrapper over assign.yml. Assign a service to a CTID:
#
#   ./zai-assign npm 104                  # npm → CTID 104 (10.1.1.104)
#   ./zai-assign npm 105 -e reassign=true # move an existing assignment
#
# Run it from this repo (e.g. /opt/zai-ops/ansible on the control node) — there's
# no copy installed elsewhere, so the script you run is always the one in git.
# No logic lives here; the playbook validates and persists the assignment.
set -euo pipefail
if [[ $# -lt 2 ]]; then
  echo "usage: ./zai-assign <service> <ctid> [extra ansible args]" >&2
  exit 64
fi
service="$1"; ctid="$2"; shift 2
# cd to this script's own directory (the ansible dir) so ansible.cfg loads no
# matter the caller's CWD — it supplies the inventory (relative: inventory/) and
# the vault password file. Self-locating (not a hardcoded path) so the same
# script works from any checkout: /opt/zai-ops on the box, a dev tree elsewhere.
cd "$(dirname "$(readlink -f "$0")")"
exec ansible-playbook assign.yml \
  -e "service=$service ctid=$ctid" "$@"
